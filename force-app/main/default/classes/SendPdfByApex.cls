public class SendPdfByApex {

    public static void sendPdfEmail() {

        // Step 1: Create HTML
        String html =
            '<html>' +
            '<body>' +
            '<h1>Welcome Anjali!</h1>' +
            '<p>This PDF is generated completely using Apex.</p>' +
            '<p>Date : ' + Date.today() + '</p>' +
            '<table border="1">' +
            '<tr>' +
            '<th>Name</th>' +
            '<th>Email</th>' +
            '</tr>' +
            '<tr>' +
            '<td>Anjali Goyal</td>' +
            '<td>anjali@test.com</td>' +
            '</tr>' +
            '</table>' +
            '</body>' +
            '</html>';

        // Step 2: Convert HTML to PDF
        Blob pdfBlob = Blob.toPdf(html);

        // Step 3: Create PDF attachment
        Messaging.EmailFileAttachment attachment =
            new Messaging.EmailFileAttachment();

        attachment.setFileName('ContactReport.pdf');
        attachment.setBody(pdfBlob);
        attachment.setContentType('application/pdf');

        // Step 4: Create Email
        Messaging.SingleEmailMessage email =
            new Messaging.SingleEmailMessage();

        email.setToAddresses(
            new String[]{
                'anjaligoyal@cyntexa.com'
            }
        );

        email.setSubject('PDF Generated By Apex');
        email.setPlainTextBody(
            'Please find the attached PDF.'
        );

        email.setFileAttachments(
            new Messaging.EmailFileAttachment[]{
                attachment
            }
        );

        // Step 5: Send Email
        Messaging.sendEmail(
            new Messaging.SingleEmailMessage[]{
                email
            }
        );
    }
}